{# ✅ Crear objeto en Twig y convertirlo a JSON #}
{% set rates = {
    cop: cop.conversion_rate,
    ves: ves.conversion_rate
} %}


<raffle-form allowinstallments="{{ allow_installments }}" showone="{{ show_one }}" payments='{{ payments | json_encode }}' raffle="{{ raffle }}" price="{{ price }}" rateexchange='{{ rates|json_encode }}'>
	<div class="skeleton-loader" style="height: 500px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; border-radius: 8px;">
		<div class="spinner" style="border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid #fb2c36; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite;"></div>
	</div>
</raffle-form>

<style>
	@keyframes spin {
		0% {
			transform: rotate(0deg);
		}
		100% {
			transform: rotate(360deg);
		}
	}
</style>
